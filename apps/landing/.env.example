# Landing app environment variables
# Copy this file to .env.local and fill in your real values.

# ── Resend (contact/request-quote emails) ────────────────
RESEND_API_KEY=
CREDIT_DELIVERY_EMAIL_FROM="IATF Solutions <noreply@iatf-solutions.com>"
ADMIN_EMAIL=

# ── Cross-domain: URL of the tool app (used by BuyCreditsButton) ─
NEXT_PUBLIC_TOOL_URL=http://localhost:3001

# ── App base URL ─────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Stripe Price IDs (inlined at build time for pricing page) ─
NEXT_PUBLIC_STRIPE_PRICE_8D_SINGLE=
NEXT_PUBLIC_STRIPE_PRICE_8D_FIVE=
NEXT_PUBLIC_STRIPE_PRICE_CSR_SINGLE=
NEXT_PUBLIC_STRIPE_PRICE_CSR_FIVE=
NEXT_PUBLIC_STRIPE_PRICE_CSR_TWENTY=
