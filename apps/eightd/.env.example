# Copy this file to .env.local and fill in your real values.
# This file is gitignored — never commit it.

# ── AI Provider ──────────────────────────────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=

# ── Redis (Upstash KV) ──────────────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Encryption ───────────────────────────────────────────
CODE_HASH_PEPPER=

# ── Session ──────────────────────────────────────────────
# Must be at least 32 characters. Generate: openssl rand -base64 32
SESSION_SECRET=
SESSION_TTL_SECONDS=86400

# ── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (optional — inline fallback prices are used if absent)
NEXT_PUBLIC_STRIPE_PRICE_8D_SINGLE=
NEXT_PUBLIC_STRIPE_PRICE_8D_FIVE=
NEXT_PUBLIC_STRIPE_PRICE_CSR_SINGLE=
NEXT_PUBLIC_STRIPE_PRICE_CSR_FIVE=
NEXT_PUBLIC_STRIPE_PRICE_CSR_TWENTY=

# ── URLs ─────────────────────────────────────────────────
BASE_URL=http://localhost:3001
NEXT_PUBLIC_TOOL_URL=http://localhost:3001

# ── Email (Resend) ───────────────────────────────────────
RESEND_API_KEY=
CREDIT_DELIVERY_EMAIL_FROM="IATF Solutions <noreply@iatf-solutions.com>"
ADMIN_EMAIL=

# ── Billing Admin ────────────────────────────────────────
BILLING_ADMIN_TOKEN=
BILLING_SUCCESS_URL=
BILLING_CANCEL_URL=
RESEND_API_KEY=
CREDIT_DELIVERY_EMAIL_FROM=
ADMIN_EMAIL=